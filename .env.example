# Copy to `.env` next to app.py (never commit real `.env`).

# 1 = fake vision captions (UI / pipeline testing without HF). 0 = real Cosmos.
MOCK_COSMOS=0

REQUIRE_LOGIN=0
LOGIN_USERNAME=your_username
LOGIN_PASSWORD=your_password

# Hugging Face model id OR local folder with downloaded weights
COSMOS_MODEL=nvidia/Cosmos-Reason2-2B
COSMOS_MODEL_LABEL=Cosmos-Reason2-2B

# Ollama (local LLM for summaries)
OLLAMA_MODEL=llama3.2
# OLLAMA_HOST=http://127.0.0.1:11434
# Long outputs for municipal report style (optional)
# OLLAMA_NUM_PREDICT_MUNICIPAL=8192

# Optional: Postgres / Supabase for vector search
# SUPABASE_DB_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

SAVE_SUMMARIES_LOCAL=1
