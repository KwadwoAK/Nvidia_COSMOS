# Copia a `.env` junto a app.py. No subas `.env` al git.

# 1 = sin Cosmos (captions mock). Útil si no puedes usar hf download / HF.
MOCK_COSMOS=0

# Login: 0 = abierto (local), 1 = pide LOGIN_USERNAME / LOGIN_PASSWORD
REQUIRE_LOGIN=0
LOGIN_USERNAME=your_username
LOGIN_PASSWORD=your_password

# Modelo Hugging Face o carpeta local con el modelo ya descargado
COSMOS_MODEL=nvidia/Cosmos-Reason2-2B
COSMOS_MODEL_LABEL=Cosmos-Reason2-2B

# Ollama (opcional)
OLLAMA_MODEL=llama3.2

# Supabase / Postgres (opcional)
# SUPABASE_DB_URL=postgresql://...

SAVE_SUMMARIES_LOCAL=1
